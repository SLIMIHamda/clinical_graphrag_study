__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/
*.egg-info/
.venv/

# Secrets — never commit. NIM / RunPod keys live in an untracked .env.
.env
*.key
secrets/

# Run artifacts live on the RunPod Network Volume, not in git.
results/per-run/
results/smoke/
results/*.parquet
figures/*.png
figures/*.pdf

# Benchmark data + corpora are large and reused from MedRAG; not in git.
# NOTE: these patterns are anchored with a leading slash on purpose. An
# unanchored `data/` matches *any* directory named data at any depth — it
# silently excluded the `mgr/data/` Python sub-package from every commit, so
# fresh clones raised `ModuleNotFoundError: No module named 'mgr.data'` while
# local tests kept passing. Keep them anchored.
/data/
/results/data/
*.jsonl
!tests/**/*.jsonl
!mgr/**/*.py
