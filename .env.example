# Copy to .env (gitignored) and fill in. Never commit real keys.

# NIM free tier — embeddings / reranker / RAGAS judge / graph extraction.
NIM_BASE_URL=https://integrate.api.nvidia.com
NIM_API_KEY=

# Local vLLM generation server (the A100 pod). Generation NEVER goes to NIM.
VLLM_BASE_URL=http://localhost:8000
VLLM_API_KEY=

# RunPod (infra/runpod scripts).
RUNPOD_API_KEY=

# Where the reused MedRAG/MIRAGE data + indices live on the pod's Network Volume.
DATA_ROOT=/vol/data/mirage
CORPUS=/vol/indices/bm25/corpus.jsonl
